# Supabase (opcional - necessario para funcionalidade de Responsaveis)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Segredo usado para assinar o contexto de callback de analise de IA
# Deve ser uma string aleatoria forte (ex: openssl rand -hex 32)
CALL_ANALYSIS_CALLBACK_SECRET=your-strong-secret-here

# Segredo para verificar assinatura do webhook inbound da API4Com (opcional)
# Se configurado, todos os webhooks devem incluir este valor no header Authorization
# ou x-api4com-signature como HMAC-SHA256 no formato "sha256=<hash>"
API4COM_WEBHOOK_SECRET=your-webhook-secret-here
